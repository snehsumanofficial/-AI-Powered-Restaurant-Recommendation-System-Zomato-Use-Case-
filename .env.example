# Phase 1/2 config
DATA_CACHE_DIR=.cache/huggingface
DATASET_NAME=ManikaSaini/zomato-restaurant-recommendation
DATASET_SPLIT=train
DATASET_REVISION=
SAMPLE_LIMIT=
LOG_LEVEL=INFO

# Phase 3 Groq config
# Set either LLM_API_KEY or GROQ_API_KEY
LLM_API_KEY=
# GROQ_API_KEY=
LLM_MODEL=llama-3.3-70b-versatile

# Live Groq connectivity test toggle
RUN_GROQ_LIVE=1
